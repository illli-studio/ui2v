{
  "name": "@ui2v/cli",
  "version": "1.0.3",
  "description": "Command-line interface for ui2v video compositions",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "ui2v": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "keywords": [
    "ui2v",
    "video",
    "animation",
    "rendering",
    "cli"
  ],
  "author": "ui2v",
  "license": "MIT",
  "homepage": "https://github.com/illli-studio/ui2v#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illli-studio/ui2v.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/illli-studio/ui2v/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ui2v/core": "1.0.3",
    "@ui2v/producer": "1.0.3",
    "@ui2v/runtime-core": "1.0.3",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "prompts": "^2.4.2",
    "fs-extra": "^11.2.0",
    "puppeteer": "^24.42.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}

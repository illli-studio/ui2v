{
  "name": "@ui2v/engine",
  "version": "1.2.0",
  "description": "Browser Canvas and WebCodecs rendering engine for ui2v video projects",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "keywords": [
    "ui2v",
    "rendering",
    "canvas",
    "webcodecs",
    "animation",
    "motion-graphics"
  ],
  "author": "ui2v",
  "license": "MIT",
  "homepage": "https://github.com/illli-studio/ui2v/tree/main/packages/engine#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illli-studio/ui2v.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/illli-studio/ui2v/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ui2v/core": "1.2.0",
    "@ui2v/runtime-core": "1.2.0"
  },
  "devDependencies": {
    "@types/animejs": "^3.1.13",
    "@types/d3": "^7.4.3",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^22.19.5",
    "@types/three": "^0.182.0",
    "mediabunny": "^1.25.1",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}

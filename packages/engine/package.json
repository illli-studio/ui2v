    "@types/d3": "^7.4.3",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^22.19.5",
    "@types/three": "^0.182.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}
